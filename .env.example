# PostgreSQL connection for database auth and future database-backed finance mode.
# Default value points to the Docker/local Postgres service in docker-compose.yml.
# Hosted providers such as Supabase, Render, Neon or Railway can replace this
# with their own PostgreSQL connection string.
DATABASE_URL="postgresql://papero:papero@localhost:5432/papero?schema=public"

# Papero data mode:
# - local: manual browser localStorage MVP flow.
# - demo: browser localStorage flow with fictional demo data auto-seeded when empty.
# - database: PostgreSQL + Better Auth mode for auth/session/workspace records
#   and database-backed core finance records.
# NEXT_PUBLIC_PAPERO_DATA_MODE is client-safe and controls current browser behavior.
# PAPERO_DATA_MODE controls server/proxy behavior, including route protection.
# These should usually be set to the same value.
# Missing/invalid mode values should fall back toward local mode where applicable.
NEXT_PUBLIC_PAPERO_DATA_MODE="local"
PAPERO_DATA_MODE="local"

# Better Auth for database mode authentication.
# Use a high-entropy value with at least 32 characters before production.
# You can generate one with: openssl rand -base64 32
# local/demo modes do not require auth.
# database mode requires PostgreSQL, Better Auth and a valid DATABASE_URL.
BETTER_AUTH_SECRET="replace-me-with-a-long-random-secret-before-production"
BETTER_AUTH_URL="http://localhost:3000"

# Optional legacy URL alias supported during the auth transition.
AUTH_URL="http://localhost:3000"

# Public app URL used by future integrations and metadata.
NEXT_PUBLIC_APP_URL="http://localhost:3000"

# Note: fresh production builds may need network access because next/font/google
# fetches optimized font assets during build.
